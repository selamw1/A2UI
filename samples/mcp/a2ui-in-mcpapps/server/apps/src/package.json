{
  "name": "basic-mcp-app-angular",
  "version": "1.0.0",
  "dependencies": {
    "@a2ui/angular": "workspace:*",
    "@a2ui/markdown-it": "workspace:*",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "build": "ng build --output-path=../dist/raw --configuration production",
