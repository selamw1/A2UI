{
  "name": "@a2ui/react-shell",
  "private": true,
  "version": "0.8.1",
  "description": "A2UI React Shell Demo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.4",
    "@a2ui/markdown-it": "workspace:*",
    "@a2ui/react": "workspace:*",
    "@a2ui/web_core": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "gts": "^7.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "wireit": "^0.15.0-pre.2"
  },
  "wireit": {
    "build": {
      "command": "tsc -b && vite build",
      "dependencies": [
        "../../../../renderers/react:build"
      ],
      "files": [
        "src/**/*",
        "index.html",
        "tsconfig.json",
        "vite.config.*"
      ],
      "output": [
        "dist/"
      ]
    }
  }
}
