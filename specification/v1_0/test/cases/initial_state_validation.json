      "data": {
        "version": "v1.0",
        "createSurface": {
          "surfaceId": "test_surface",
          "catalogId": "https://a2ui.org/specification/v1_0/catalogs/basic/catalog.json",
          "components": [
            {
              "id": "root",
              "component": "Text",
              "text": "Minimal components configuration"
            }
          ]
        }
      }
    },
    {
