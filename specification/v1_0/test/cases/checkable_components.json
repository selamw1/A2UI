    {
      "description": "TextField with complex logic checks (AND/OR/NOT)",
      "valid": true,
      "data": {
        "version": "v1.0",
        "updateComponents": {
          "surfaceId": "test_1",
          "components": [
            {
              "id": "tf_complex",
              "component": "TextField",
              "label": "Secret Code",
              "value": {
                "path": "/formData/code"
              },
              "checks": [
                {
                  "condition": {
                    "call": "and",
                    "args": {
                      "values": [
                        {
                          "call": "required",
                          "args": {
                            "value": {
                              "path": "/formData/code"
                            }
                          }
                        },
                        {
                          "call": "or",
                          "args": {
                            "values": [
                              {
                                "call": "regex",
                                "args": {
                                  "value": {
                                    "path": "/formData/code"
                                  },
                                  "pattern": "^[A-Z]"
                                }
                              },
                              {
                                "call": "not",
                                "args": {
                                  "value": {
                                    "call": "regex",
                                    "args": {
                                      "value": {
                                        "path": "/formData/code"
                                      },
                                      "pattern": "^[0-9]"
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  "message": "Code must start with letter or not start with number"
                }
              ]
            }
          ]
        }
      }
