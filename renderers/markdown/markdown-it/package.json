{
  "name": "@a2ui/markdown-it",
  "version": "0.0.4",
  "description": "A Markdown renderer using markdown-it and dompurify.",
  "repository": {
    "directory": "renderers/markdown/markdown-it",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "markdown",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "license": "Apache-2.0",
  "author": "Google",
  "type": "module",
  "main": "./dist/src/markdown.js",
  "types": "./dist/src/markdown.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/markdown.d.ts",
      "default": "./dist/src/markdown.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "build": "wireit",
    "lint": "gts lint",
    "lint:fix": "gts fix",
    "format": "prettier --ignore-path ../.gitignore --write .",
    "format:check": "prettier --ignore-path ../.gitignore --check .",
    "prepublishOnly": "node -e \"if(!process.cwd().endsWith('dist')) { console.error('Error: This package must be published from the dist/ directory. Run `yarn build` then `cd dist && yarn npm publish`'); process.exit(1); }\"",
    "publish:package": "yarn build && node ../../scripts/prepare-publish.mjs && cd dist && touch yarn.lock && yarn install && yarn npm publish --access public",
    "test": "wireit",
    "clean": "wireit"
  },
  "dependencies": {
    "dompurify": "3.3.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@a2ui/web_core": "workspace:*",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.37.0",
    "gts": "^7.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "typescript": "5.9.3",
    "wireit": "^0.15.0-pre.2"
  },
  "peerDependencies": {
    "@a2ui/web_core": "workspace:*"
  },
  "wireit": {
    "build": {
      "command": "tsc -b --pretty",
      "dependencies": [
        "../../../renderers/web_core:build"
      ],
      "files": [
        "src/**/*.ts",
        "src/**/*.json",
        "tsconfig.json"
      ],
      "output": [
        "dist/",
        "!dist/**/*.min.js{,.map}"
      ],
      "clean": "if-file-deleted"
    },
    "test": {
      "command": "node --test --enable-source-maps --test-reporter spec dist/src/*.test.js",
      "dependencies": [
        "build"
      ]
    },
    "clean": {
      "command": "rm -rf dist .tsbuildinfo .wireit"
    }
  }
}
