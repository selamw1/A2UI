{
  "name": "@a2ui/lit",
  "version": "0.10.0",
  "description": "A2UI Lit Library",
  "author": "Google",
  "license": "Apache-2.0",
  "homepage": "https://a2ui.org/",
  "repository": {
    "directory": "renderers/lit",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "lit",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./0.8": {
      "types": "./dist/src/0.8/core.d.ts",
      "default": "./dist/src/0.8/core.js"
    },
    "./v0_8": {
      "types": "./dist/src/0.8/core.d.ts",
      "default": "./dist/src/0.8/core.js"
    },
    "./v0_9": {
      "types": "./dist/src/v0_9/index.d.ts",
      "default": "./dist/src/v0_9/index.js"
    },
    "./ui": {
      "types": "./dist/src/0.8/ui/ui.d.ts",
      "default": "./dist/src/0.8/ui/ui.js"
    }
  },
  "type": "module",
  "scripts": {
    "prepublishOnly": "node -e \"if(!process.cwd().endsWith('dist')) { console.error('Error: This package must be published from the dist/ directory. Run `yarn build` then `cd dist && yarn npm publish`'); process.exit(1); }\"",
    "publish:package": "yarn build && node ../scripts/prepare-publish.mjs && cd dist && touch yarn.lock && yarn install && yarn npm publish --access public",
    "build": "wireit",
    "build:tsc": "wireit",
    "dev": "yarn serve --watch",
    "test": "wireit",
    "test:unit": "wireit",
    "test:integration": "wireit",
    "demo": "yarn workspace @a2ui/lit-explorer dev",
    "lint": "gts lint",
    "lint:fix": "gts fix",
    "clean": "wireit"
  },
  "wireit": {
    "test": {
      "dependencies": [
        "test:unit",
        "test:integration"
      ]
    },
    "test:unit": {
      "command": "node --test --enable-source-maps --test-reporter spec dist/src/0.8/*.test.js dist/src/v0_9/tests/*.test.js dist/src/v0_9/tests/**/*.test.js",
      "dependencies": [
        "build"
      ]
    },
    "test:integration": {
      "command": "yarn workspace @a2ui/lit-explorer test:ci"
    },
    "build": {
      "dependencies": [
        "build:tsc"
      ]
    },
    "build:tsc": {
      "command": "tsc -b --pretty",
      "dependencies": [
        "../../renderers/web_core:build"
      ],
      "env": {
        "FORCE_COLOR": "1"
      },
      "files": [
        "src/**/*.ts",
        "src/**/*.json",
        "tsconfig.json"
      ],
      "output": [
        "dist/",
        "!dist/**/*.min.js{,.map}"
      ],
      "clean": "if-file-deleted"
    },
    "clean": {
      "command": "rm -rf dist .tsbuildinfo .wireit"
    }
  },
  "files": [
    "dist/src"
  ],
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.37.0",
    "google-artifactregistry-auth": "^3.5.0",
    "gts": "^7.0.0",
    "jsdom": "^25.0.0",
    "typescript": "5.9.3",
    "wireit": "^0.15.0-pre.2"
  },
  "peerDependencies": {
    "@a2ui/markdown-it": "*"
  },
  "peerDependenciesMeta": {
    "@a2ui/markdown-it": {
      "optional": true
    }
  },
  "dependencies": {
    "@a2ui/web_core": "workspace:*",
    "@lit-labs/signals": "^0.1.3",
    "@lit/context": "^1.1.4",
    "lit": "^3.3.1",
    "signal-utils": "^0.21.1",
    "zod": "^3.25.76"
  }
}
