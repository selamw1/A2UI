{
  "name": "@a2ui/angular",
  "version": "0.10.0",
  "license": "Apache-2.0",
  "homepage": "https://a2ui.org/",
  "repository": {
    "directory": "renderers/angular",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "angular",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "scripts": {
    "generate-examples": "node scripts/generate-examples.mjs",
    "build": "wireit",
    "prepublishOnly": "node -e \"if(!process.cwd().endsWith('dist')) { console.error('Error: This package must be published from the dist/ directory. Run `yarn build` then `cd dist && yarn npm publish`'); process.exit(1); }\"",
    "publish:package": "yarn build && cd dist && touch yarn.lock && yarn install && yarn npm publish --access public",
    "demo": "yarn generate-examples && ng serve a2ui_explorer",
    "test": "wireit",
    "test:watch": "yarn generate-examples && ng test lib --browsers=ChromeHeadless",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "wireit"
  },
  "dependencies": {
    "@a2ui/web_core": "workspace:*",
    "@preact/signals-core": "^1.13.0",
    "tslib": "^2.3.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@a2ui/markdown-it": "*",
    "@angular/common": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/platform-browser": "^21.2.5"
  },
  "peerDependenciesMeta": {
    "@a2ui/markdown-it": {
      "optional": true
    }
  },
  "devDependencies": {
    "@a2ui/markdown-it": "workspace:*",
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "@types/uuid": "^10.0.0",
    "@vitest/browser": "^4.0.15",
    "cypress": "^15.6.0",
    "eslint": "^9.37.0",
    "google-artifactregistry-auth": "^3.5.0",
    "gts": "^7.0.0",
    "jasmine-core": "~5.9.0",
    "jsdom": "^27.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^21.0.0",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vitest": "^4.0.15",
    "wireit": "^0.15.0-pre.2"
  },
  "sideEffects": false,
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "wireit": {
    "build": {
      "command": "yarn generate-examples && ng build && node ../scripts/prepare-publish.mjs --source ./dist/package.json --skip-path-adjustment",
      "dependencies": [
        "../../renderers/web_core:build",
        "../../renderers/markdown/markdown-it:build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json",
        "scripts/**/*"
      ],
      "output": [
        "dist/"
      ]
    },
    "test": {
      "command": "yarn generate-examples && ng test lib --watch=false --browsers=ChromeHeadless",
      "dependencies": [
        "build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json"
      ]
    },
    "clean": {
      "command": "rm -rf dist projects/mcp_calculator/dist projects/orchestrator/dist .tsbuildinfo .wireit"
    }
  },
  "resolutions": {
    "@preact/signals-core": "^1.13.0"
  }
}
